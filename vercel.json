{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "rewrites": [
        {
            "source": "/(css|js|images|uploads)/(.*)",
            "destination": "/$1/$2"
        },
        {
            "source": "/admin",
            "destination": "/api/admin/dashboard.php"
        },
        {
            "source": "/admin/:path.php",
            "destination": "/api/admin/:path.php"
        },
        {
            "source": "/admin/:path",
            "destination": "/api/admin/:path.php"
        },
        {
            "source": "/student",
            "destination": "/api/student/dashboard.php"
        },
        {
            "source": "/student/:path.php",
            "destination": "/api/student/:path.php"
        },
        {
            "source": "/student/:path",
            "destination": "/api/student/:path.php"
        },
        {
            "source": "/login.php",
            "destination": "/api/login.php"
        },
        {
            "source": "/login",
            "destination": "/api/login.php"
        },
        {
            "source": "/logout.php",
            "destination": "/api/logout.php"
        },
        {
            "source": "/logout",
            "destination": "/api/logout.php"
        },
        {
            "source": "/",
            "destination": "/api/index.php"
        },
        {
            "source": "/:path.php",
            "destination": "/api/:path.php"
        },
        {
            "source": "/:path",
            "destination": "/api/:path.php"
        }
    ]
}